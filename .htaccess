# CEDRUMO website — Apache configuration for IONOS Webhosting Standard
#
# Order matters: HTTPS first, then host canonicalisation, then URL hygiene,
# then security headers, then long-cache for static assets.

# -----------------------------------------------------------------------------
# 1. Rewrites
# -----------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # HTTP -> HTTPS (Apple App Store + Google Play require a durable HTTPS
  # privacy URL; this is also the foundation for HSTS below).
  RewriteCond %{HTTPS} !=on
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

  # www -> apex (cedrumo.com is canonical; www. is allowed by DNS but should
  # never be the indexed form).
  RewriteCond %{HTTP_HOST} ^www\.cedrumo\.com$ [NC]
  RewriteRule ^(.*)$ https://cedrumo.com/$1 [R=301,L]

  # /path/index.html -> /path/ (collapse implicit index file in the URL).
  RewriteCond %{THE_REQUEST} \s/+(.*)index\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]
</IfModule>

# -----------------------------------------------------------------------------
# 2. Custom error pages
# -----------------------------------------------------------------------------
ErrorDocument 404 /404.html

# -----------------------------------------------------------------------------
# 3. Security headers
# -----------------------------------------------------------------------------
<IfModule mod_headers.c>
  # Lock browsers to HTTPS for one year after first visit.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

  # Block MIME-type sniffing.
  Header always set X-Content-Type-Options "nosniff"

  # Disallow framing from foreign origins (clickjacking).
  Header always set X-Frame-Options "SAMEORIGIN"

  # Send minimal referrer info to other origins.
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # No browser features need explicit allow; deny what we don't use.
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), accelerometer=(), gyroscope=(), magnetometer=()"

  # Content Security Policy. The only third-party origin is Plausible
  # Analytics (privacy-friendly, cookieless, EU-hosted): its script loads
  # from plausible.io and events post there, so plausible.io is allowed in
  # script-src and connect-src. 'unsafe-inline' covers the language-redirect
  # inline script on /index.html; the site has zero user-generated content
  # and zero XSS surface.
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://plausible.io; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://plausible.io; base-uri 'self'; form-action 'none'; frame-ancestors 'self'; object-src 'none'"

  # Allow intermediate caches to vary on encoding (Apache already sends
  # Vary: Cookie; this appends Accept-Encoding so gzip/identity differ).
  Header append Vary Accept-Encoding
</IfModule>

# -----------------------------------------------------------------------------
# 4. Long-cache on static assets (immutable content under /assets/)
# -----------------------------------------------------------------------------
<IfModule mod_headers.c>
  <FilesMatch "\.(woff2|woff|ttf|otf|css|js|png|jpg|jpeg|webp|gif|svg|ico|avif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# Fallback for hosts without mod_headers (Expires module path).
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# -----------------------------------------------------------------------------
# 5. Gzip compression (best-effort; IONOS usually has mod_deflate enabled)
# -----------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json application/xml image/svg+xml
</IfModule>

# -----------------------------------------------------------------------------
# 6. Correct MIME types (some shared hosts ship outdated defaults)
# -----------------------------------------------------------------------------
<IfModule mod_mime.c>
  AddType font/woff2 .woff2
  AddType image/svg+xml .svg
  AddType image/webp .webp
  AddType image/avif .avif
</IfModule>
